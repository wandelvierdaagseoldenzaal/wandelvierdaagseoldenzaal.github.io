{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "jekyll dev",
        "command": "bundle exec jekyll serve",
        "type": "shell",
        "group": { "kind": "build", "isDefault": true }
      },
      {
        "label": "jekyll dev incremental",
        "command": "bundle exec jekyll serve --incremental",
        "type": "shell",
        "group": { "kind": "build", "isDefault": true }
      },      
      {
        "label": "jekyll production",
        "command": "$env:JEKYLL_ENV='production'; bundle exec jekyll serve",
        "type": "shell"
      },
      {
        "label": "Genereer Photobook Data",
        "command": "ruby generate_photobook_data.rb",
        "type": "shell",
        "group": "build",
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared",
          "showReuseMessage": true,
          "clear": false
        },
        "problemMatcher": []
      }
    ]
  }